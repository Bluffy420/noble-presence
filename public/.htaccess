# ── Trailing-slash redirect ────────────────────────────────────────────────────
# Vite outputs dist/team/, dist/services/, etc. as real directories.
# Hostinger/Apache sees these directories and 301 → /team/, then 403s on
# directory listing. Strip the slash first so the SPA rewrite always fires.

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1. Remove trailing slash (except for root "/")
  #    /team/ → /team, /services/ → /services, etc.
  RewriteCond %{REQUEST_URI} ^(.+)/$
  RewriteCond %{REQUEST_URI} !^/$
  RewriteRule ^ %1 [R=301,L]

  # 2. Let real FILES through (JS/CSS chunks, images, shell.json, favicon…)
  #    Do NOT pass directories through — Vite route dirs must not be served.
  RewriteCond %{REQUEST_FILENAME} !-f

  # 3. Everything else (including route dirs like /team, /services) → index.html
  RewriteRule ^ index.html [L]
</IfModule>

# ── CORS for shell.json (WordPress connector) ─────────────────────────────────
<IfModule mod_headers.c>
  <FilesMatch "^shell\.json$">
    Header set Access-Control-Allow-Origin "https://nbassociates.net"
    Header set Cache-Control "public, max-age=3600, stale-while-revalidate=86400"
  </FilesMatch>
</IfModule>

# ── Disable directory listing (belt-and-suspenders) ───────────────────────────
Options -Indexes
